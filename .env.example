# ==============================================================================
# SONG GENERATOR CONFIGURATION
# Copy this file to .env and fill in your values.
# Get your API key at: https://aistudio.google.com/app/apikey
# ==============================================================================

# Required
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================================================
# DUAL-MODEL OPTIMIZATION (recommended - uses cheap Flash for validation,
# expensive Pro only for song generation)
# ==============================================================================
USE_DUAL_MODELS=true

FLASH_MODEL=gemini-2.5-flash-lite
FLASH_MODEL_BACKUP=gemini-2.0-flash
PRO_MODEL=gemini-2.5-pro

# Legacy single-model mode (used when USE_DUAL_MODELS=false)
GEMINI_MODEL=gemini-2.5-flash-lite

# ==============================================================================
# QUALITY CONTROL
# ==============================================================================

# Hindi grammar/poetry quality (8 = excellent, 9-10 = may cause more retries)
HINDI_THRESHOLD=8

# Rhythm + melody singability (7 recommended for cost savings)
SINGABILITY_THRESHOLD=7

# Cultural/religious sensitivity (7 = respectful with creative freedom)
CULTURAL_THRESHOLD=7

# How many times to regenerate if quality check fails (0 = no retries)
MAX_QUALITY_RETRIES=2

# Set to false to skip all quality checks (ultra-fast testing mode)
ENABLE_QUALITY_CHECKS=true

# true = refine existing lyrics on failure (cheaper, preserves good parts)
# false = regenerate from scratch (expensive)
USE_ITERATIVE_REFINEMENT=true

# Skip the final polish pass (Chain 4) - faster and cheaper
SKIP_CHAIN4_REFINE=false

# Auto-detect and complete truncated lyrics (~$0.0025 per retry, ~2% of songs)
AUTO_COMPLETE_TRUNCATED=true

# ==============================================================================
# COST REFERENCE (dual-model mode, quality=8, retries=2)
# ==============================================================================
# Per song:  ~$0.015–0.020   |   Time: ~25–40 s   |   Quality: excellent
# 100 songs: ~$1.50–2.00
